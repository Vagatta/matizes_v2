---
import MatizesVertical from '../components/MatizesVertical.astro';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (typeof window !== 'undefined') && ((window).FontAwesomeConfig = { autoReplaceSvg: 'nest' });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer" is:inline></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style is:global>
        ::-webkit-scrollbar { display: none; }
        html { scroll-behavior: smooth; }
        section[id] { scroll-margin-top: 5rem; }
        body { font-family: 'Jost', sans-serif; }
        h1, h2, h3, .serif { font-family: 'Cormorant Garamond', serif; }
        .nav-link { position: relative; text-decoration: none !important; }
        .nav-link::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1px; background: #B0B30B; transition: width 0.3s ease; }
        .nav-link:hover::after { width: 100%; }
        .hero-overlay { background: linear-gradient(135deg, rgba(130,0,87,0.82) 0%, rgba(130,0,87,0.4) 60%, rgba(0,0,0,0.1) 100%); }
        .gold-line { background: linear-gradient(90deg, transparent, #B0B30B, transparent); }
        .card-hover { transition: transform 0.3s ease, box-shadow 0.3s ease; }
        .card-hover:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(130,0,87,0.18); }
        .btn-gold { background: #B0B30B; color: #820057; transition: all 0.3s ease; }
        .btn-gold:hover { background: #820057; color: #B0B30B; }
        .btn-purple { background: #820057; color: #B0B30B; transition: all 0.3s ease; }
        .btn-purple:hover { background: #B0B30B; color: #820057; }
        .section-tag { letter-spacing: 0.25em; font-size: 0.7rem; text-transform: uppercase; color: #B0B30B; }
        .testimonial-card { border-left: 3px solid #B0B30B; }
        .logo-exclamation { color: #B0B30B; }
        a { text-decoration: none !important; }
    </style>
</head>
<body class="bg-cream text-gray-800 overflow-x-hidden">
    <div id="splash-screen" aria-hidden="true" style="display:none" class="fixed inset-0 z-[9999] flex items-center justify-center cursor-pointer bg-[#faf8f4] transition-opacity duration-700">
      <div class="pointer-events-none absolute inset-5 lg:inset-8 border border-[#B0B30B]/25"></div>
      <span class="pointer-events-none absolute top-5 left-5 lg:top-8 lg:left-8 w-10 h-10 border-t-2 border-l-2 border-[#B0B30B]/60"></span>
      <span class="pointer-events-none absolute top-5 right-5 lg:top-8 lg:right-8 w-10 h-10 border-t-2 border-r-2 border-[#B0B30B]/60"></span>
      <span class="pointer-events-none absolute bottom-5 left-5 lg:bottom-8 lg:left-8 w-10 h-10 border-b-2 border-l-2 border-[#B0B30B]/60"></span>
      <span class="pointer-events-none absolute bottom-5 right-5 lg:bottom-8 lg:right-8 w-10 h-10 border-b-2 border-r-2 border-[#B0B30B]/60"></span>
      <div class="splash-card relative z-10 flex flex-col items-center text-center text-[#820057]">
        <MatizesVertical class="h-[50vh] max-h-[440px] w-auto" />
      </div>
    </div>
    <slot />
    <script>
      import '../scripts/cart';
    </script>
    <script is:inline>
      (function () {
        try {
          if (sessionStorage.getItem('matizes_splash_shown') === '1') return;
          var el = document.getElementById('splash-screen');
          if (!el) return;
          el.style.display = 'flex';
          function dismiss() {
            if (el.dataset.dismissed) return;
            el.dataset.dismissed = '1';
            el.style.opacity = '0';
            setTimeout(function () { el.remove(); }, 700);
            try { sessionStorage.setItem('matizes_splash_shown', '1'); } catch (e) {}
          }
          el.addEventListener('click', dismiss);
          setTimeout(dismiss, 3000);
        } catch (e) {}
      })();
    </script>
</body>
</html>
