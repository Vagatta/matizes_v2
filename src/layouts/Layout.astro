---
import MatizesVertical from '../components/MatizesVertical.astro';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="overflow-x-hidden">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (typeof window !== 'undefined') && ((window).FontAwesomeConfig = { autoReplaceSvg: 'nest' });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer" is:inline></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/animations.css" />
    <style is:global>
        ::-webkit-scrollbar { display: none; }
        html { scroll-behavior: smooth; }
        section[id] { scroll-margin-top: 5rem; }
        *, *::before, *::after { font-family: 'Cormorant Garamond', serif !important; }
        /* Excepción: iconos Font Awesome — usan su propia fuente de iconos */
        .fa, .fas, .far, .fal, .fab, .fa-solid, .fa-regular, .fa-brands,
        [class*=" fa-"], [class^="fa-"] { font-family: "Font Awesome 6 Free", "Font Awesome 6 Brands" !important; }
        .nav-link { position: relative; text-decoration: none !important; }
        .nav-link::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1px; background: #C9A84C; transition: width 0.3s ease; }
        .nav-link:hover::after { width: 100%; }
        .hero-overlay { background: linear-gradient(135deg, rgba(130,0,87,0.82) 0%, rgba(130,0,87,0.4) 60%, rgba(0,0,0,0.1) 100%); }
        .gold-line { background: linear-gradient(90deg, transparent, #C9A84C, transparent); }
        .btn-gold { background: #C9A84C; color: #820057; }
        .btn-gold:hover { background: #820057; color: #C9A84C; }
        .btn-purple { background: #820057; color: #C9A84C; }
        .btn-purple:hover { background: #C9A84C; color: #820057; }
        .section-tag { letter-spacing: 0.25em; font-size: 0.7rem; text-transform: uppercase; color: #C9A84C; }
        .testimonial-card { border-left: 3px solid #C9A84C; }
        .logo-exclamation { color: #C9A84C; }
        a { text-decoration: none !important; }
    </style>
</head>
<body class="bg-cream text-gray-800 overflow-x-hidden w-full">
    <!-- ===================== SPLASH SCREEN ===================== -->
    <style>
      /* --- Base --- */
      #splash-screen {
        background: #faf8f4;
        transition: transform 0.85s cubic-bezier(0.76, 0, 0.24, 1);
      }
      #splash-screen.splash-out {
        transform: translateY(-100%);
      }

      /* --- Logo entrance --- */
      @keyframes splashLogoIn {
        from { opacity: 0; transform: scale(0.88) translateY(18px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
      }
      #splash-logo {
        animation: splashLogoIn 1s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both;
      }

      /* --- Corner brackets draw in --- */
      @keyframes bracketTL {
        from { width: 0; height: 0; }
        to   { width: 2.5rem; height: 2.5rem; }
      }
      @keyframes bracketBR {
        from { width: 0; height: 0; }
        to   { width: 2.5rem; height: 2.5rem; }
      }
      .splash-corner {
        position: absolute;
        width: 0;
        height: 0;
        border-color: #C9A84C;
        border-style: solid;
        overflow: hidden;
        animation: bracketTL 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }
      .splash-corner-tl { top: 1.5rem; left: 1.5rem; border-width: 2px 0 0 2px; animation-delay: 0.1s; }
      .splash-corner-tr { top: 1.5rem; right: 1.5rem; border-width: 2px 2px 0 0; animation-delay: 0.2s; }
      .splash-corner-bl { bottom: 1.5rem; left: 1.5rem; border-width: 0 0 2px 2px; animation-delay: 0.3s; }
      .splash-corner-br { bottom: 1.5rem; right: 1.5rem; border-width: 0 2px 2px 0; animation-delay: 0.4s; }
      @media (min-width: 1024px) {
        .splash-corner-tl { top: 2rem; left: 2rem; }
        .splash-corner-tr { top: 2rem; right: 2rem; }
        .splash-corner-bl { bottom: 2rem; left: 2rem; }
        .splash-corner-br { bottom: 2rem; right: 2rem; }
        .splash-corner { animation-name: bracketBR; }
        @keyframes bracketBR {
          from { width: 0; height: 0; }
          to   { width: 3rem; height: 3rem; }
        }
      }

      /* --- Inner frame fade in --- */
      @keyframes splashFrameIn {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      #splash-inner-border {
        position: absolute;
        inset: 3.5rem;
        border: 1px solid rgba(201, 168, 76, 0.2);
        animation: splashFrameIn 0.8s ease 0.6s both;
        pointer-events: none;
      }

      /* --- Gold rule above/below logo --- */
      @keyframes splashLineGrow {
        from { transform: scaleX(0); opacity: 0; }
        to   { transform: scaleX(1); opacity: 1; }
      }
      .splash-line {
        display: block;
        width: 4rem;
        height: 1px;
        background: linear-gradient(90deg, transparent, #C9A84C, transparent);
        transform-origin: center;
        animation: splashLineGrow 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.9s both;
      }

      /* --- Hint text pulse --- */
      @keyframes splashPulse {
        0%, 100% { opacity: 0.35; }
        50%       { opacity: 0.85; }
      }
      #splash-hint {
        font-family: 'Jost', sans-serif;
        font-size: 0.6rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #820057;
        animation: splashFadeIn 0.6s ease 1.4s both, splashPulse 2s ease 2s infinite;
      }
      @keyframes splashFadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 0.35; transform: translateY(0); }
      }

      /* --- Progress bar --- */
      @keyframes splashProgress {
        from { transform: scaleX(0); }
        to   { transform: scaleX(1); }
      }
      #splash-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: #C9A84C;
        transform-origin: left center;
        transform: scaleX(0);
        animation: splashProgress 3s linear 0.3s forwards;
      }
    </style>

    <div id="splash-screen" aria-hidden="true" style="display:none" class="fixed inset-0 z-[9999] flex items-center justify-center cursor-pointer">
      <!-- Animated corner brackets -->
      <span class="splash-corner splash-corner-tl pointer-events-none"></span>
      <span class="splash-corner splash-corner-tr pointer-events-none"></span>
      <span class="splash-corner splash-corner-bl pointer-events-none"></span>
      <span class="splash-corner splash-corner-br pointer-events-none"></span>
      <!-- Inner frame -->
      <div id="splash-inner-border"></div>
      <!-- Progress bar -->
      <div id="splash-progress"></div>

      <!-- Logo + lines + hint -->
      <div class="relative z-10 flex flex-col items-center gap-4 text-[#820057]">
        <span class="splash-line"></span>
        <div id="splash-logo">
          <MatizesVertical class="h-[42vh] max-h-[380px] w-auto" />
        </div>
        <span class="splash-line"></span>
        <p id="splash-hint">Toca para continuar</p>
      </div>
    </div>
    <slot />
    <script>
      import '../scripts/cart';
    </script>
    <script is:inline>
      (function () {
        try {
          if (sessionStorage.getItem('matizes_splash_shown') === '1') return;
          var el = document.getElementById('splash-screen');
          if (!el) return;
          el.style.display = 'flex';
          function dismiss() {
            if (el.dataset.dismissed) return;
            el.dataset.dismissed = '1';
            el.classList.add('splash-out');
            setTimeout(function () { el.remove(); }, 880);
            try { sessionStorage.setItem('matizes_splash_shown', '1'); } catch (e) {}
          }
          el.addEventListener('click', dismiss);
          setTimeout(dismiss, 3300);
        } catch (e) {}
      })();
    </script>

    <script is:inline>
      /* ---- Scroll-reveal IntersectionObserver ---- */
      (function () {
        if (!('IntersectionObserver' in window)) {
          /* Fallback: show everything immediately */
          document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale,.stagger-grid').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }

        var revealObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08 });

        document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale,.stagger-grid').forEach(function (el) {
          revealObs.observe(el);
        });
      })();

      /* ---- Stat / number counter ---- */
      (function () {
        var counterObs;
        var counters = document.querySelectorAll('[data-stat-target]');
        if (!counters.length) return;

        function animateCounter(el) {
          var target = parseFloat(el.dataset.statTarget);
          var duration = parseInt(el.dataset.statDuration || '1800', 10);
          var suffix = el.dataset.statSuffix || '';
          var decimals = el.dataset.statDecimals ? parseInt(el.dataset.statDecimals, 10) : 0;
          var start = null;

          function step(ts) {
            if (!start) start = ts;
            var progress = Math.min((ts - start) / duration, 1);
            /* easeOutExpo */
            var eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
            var current = eased * target;
            el.textContent = current.toFixed(decimals).replace('.', ',') + suffix;
            if (progress < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }

        if ('IntersectionObserver' in window) {
          counterObs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                animateCounter(entry.target);
                counterObs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.5 });
          counters.forEach(function (el) { counterObs.observe(el); });
        } else {
          counters.forEach(animateCounter);
        }
      })();
    </script>

    <!-- ===== TEMP: Color picker oro ===== -->
    <div id="color-picker-panel" style="
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 9998;
      background: #1a1a1a;
      border: 1px solid rgba(201,168,76,0.4);
      font-family: 'Jost', sans-serif;
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      min-width: 180px;
    ">
      <button id="color-picker-toggle" style="
        display:flex;align-items:center;justify-content:space-between;
        width:100%;padding:10px 14px;background:none;border:none;
        cursor:pointer;color:rgba(255,255,255,0.4);font-family:'Jost',sans-serif;
        font-size:9px;letter-spacing:0.2em;text-transform:uppercase;
      ">
        <span>Estudio cromático</span>
        <span id="color-picker-arrow" style="font-size:10px;transition:transform 0.2s">▲</span>
      </button>
      <div id="color-picker-body" style="padding:0 14px 12px;display:flex;flex-direction:column;gap:6px">
        <div style="display:flex;flex-direction:column;gap:6px" id="color-options">
          <!-- opciones inyectadas por JS -->
        </div>
        <div id="hero-switch-section" style="display:none;border-top:1px solid rgba(255,255,255,0.1);margin-top:6px;padding-top:10px">
          <p style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin:0 0 6px">Diseño del hero</p>
          <div style="display:flex;gap:6px">
            <button id="hero-variant-classic" data-variant="classic" class="hero-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:'Jost',sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Clásico</button>
            <button id="hero-variant-stitch" data-variant="stitch" class="hero-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:'Jost',sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Editorial</button>
            <button id="hero-variant-3d" data-variant="3d" class="hero-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:'Jost',sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">3D</button>
          </div>
        </div>
      </div>
    </div>
    <script is:inline>
      (function () {
        var GOLD_RGB = 'rgb(201,168,76)';
        var current = null;

        var options = [
          { id: 'gold',   color: '#C9A84C', label: 'Oro original'  },
          { id: 'sage',   color: '#8A9E7E', label: 'Verde salvia'  },
          { id: 'slate',  color: '#7A8FA6', label: 'Azul pizarra'  },
          { id: 'sand',   color: '#C4A882', label: 'Arena dorada'  },
          { id: 'rose',   color: '#C4828A', label: 'Rosa palo'     },
          { id: 'ivory',  color: '#F0EAD6', label: 'Marfil'        },
        ];

        function toRgbNorm(hex) {
          var r = parseInt(hex.slice(1,3),16);
          var g = parseInt(hex.slice(3,5),16);
          var b = parseInt(hex.slice(5,7),16);
          return 'rgb(' + r + ',' + g + ',' + b + ')';
        }

        function colorsMatch(a, b) {
          return a.replace(/\s/g,'') === b.replace(/\s/g,'');
        }

        function applyColor(targetHex) {
          var fromRgb = current ? toRgbNorm(current) : GOLD_RGB;
          document.querySelectorAll('.btn-gold, .btn-purple').forEach(function (el) {
            var cs = window.getComputedStyle(el);
            ['color','background-color','border-top-color','border-bottom-color','border-left-color','border-right-color'].forEach(function (prop) {
              var val = cs.getPropertyValue(prop).replace(/\s/g,'');
              if (colorsMatch(val, fromRgb)) {
                el.style.setProperty(prop, targetHex, 'important');
              }
            });
          });
          current = targetHex;
        }

        /* Collapse / expand */
        var toggleBtn = document.getElementById('color-picker-toggle');
        var body = document.getElementById('color-picker-body');
        var arrow = document.getElementById('color-picker-arrow');
        var collapsed = false;
        toggleBtn.addEventListener('click', function () {
          collapsed = !collapsed;
          body.style.display = collapsed ? 'none' : 'flex';
          arrow.style.transform = collapsed ? 'rotate(180deg)' : 'rotate(0deg)';
        });

        /* Build UI */
        var container = document.getElementById('color-options');
        options.forEach(function (opt) {
          var row = document.createElement('button');
          row.style.cssText = 'display:flex;align-items:center;gap:8px;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;width:100%;text-align:left;transition:border-color 0.2s';
          row.innerHTML =
            '<span style="width:14px;height:14px;border-radius:50%;background:' + opt.color + ';flex-shrink:0;border:1px solid rgba(255,255,255,0.15)"></span>' +
            '<span style="font-family:Jost,sans-serif;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.6)">' + opt.label + '</span>';
          row.dataset.colorId = opt.id;
          row.addEventListener('mouseenter', function () { row.style.borderColor = 'rgba(201,168,76,0.5)'; });
          row.addEventListener('mouseleave', function () { row.style.borderColor = 'rgba(255,255,255,0.08)'; });
          row.addEventListener('click', function () {
            applyColor(opt.color);
            /* mark active */
            container.querySelectorAll('button').forEach(function (b) {
              b.style.borderColor = 'rgba(255,255,255,0.08)';
            });
            row.style.borderColor = opt.color;
          });
          container.appendChild(row);
        });

        /* ---- Hero variant switch (solo si la página tiene ambos heroes) ---- */
        if (document.getElementById('hero') && document.getElementById('hero-stitch') && document.getElementById('hero-3d')) {
          var section = document.getElementById('hero-switch-section');
          section.style.display = 'block';
          var btns = section.querySelectorAll('.hero-variant-btn');

          function markActive(variant) {
            btns.forEach(function (b) {
              var active = b.dataset.variant === variant;
              b.style.borderColor = active ? '#C9A84C' : 'rgba(255,255,255,0.08)';
              b.style.color = active ? '#C9A84C' : 'rgba(255,255,255,0.6)';
            });
          }

          var savedVariant = 'classic';
          try { savedVariant = localStorage.getItem('matizes_hero_variant') || 'classic'; } catch (e) {}
          markActive(savedVariant);

          btns.forEach(function (b) {
            b.addEventListener('click', function () {
              var v = b.dataset.variant;
              try { localStorage.setItem('matizes_hero_variant', v); } catch (e) {}
              markActive(v);
              document.dispatchEvent(new CustomEvent('hero:variant', { detail: v }));
            });
          });
        }
      })();
    </script>
    <!-- ===== /TEMP ===== -->
</body>
</html>
