---
import MatizesVertical from '../components/MatizesVertical.astro';

export interface Props {
	title: string;
	description?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogImage?: string;
	ogUrl?: string;
	ogType?: string;
}

const {
	title,
	description = 'Pastelería fina artesanal en Valladolid. Creaciones de autor, tartas, cheesecakes, viennoiserie y regalos dulces elaborados con ingredientes selectos.',
	ogTitle = title,
	ogDescription = description,
	ogImage = 'https://storage.googleapis.com/uxpilot-auth.appspot.com/3fd9c28d4d-cd1f86b109f2f92c0c84.png',
	ogUrl = 'https://matizes.es',
	ogType = 'website',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="overflow-x-hidden">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Mat!zes" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={ogUrl} />
    <script is:inline>
      (typeof window !== 'undefined') && ((window).FontAwesomeConfig = { autoReplaceSvg: 'nest' });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer" is:inline></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/animations.css" />
    <style is:global>
        ::-webkit-scrollbar { display: none; }
        html { scroll-behavior: smooth; }
        .heart-icon {
          fill: none;
          stroke: currentColor;
          stroke-width: 2;
          stroke-linecap: round;
          stroke-linejoin: round;
        }
        .heart-btn.active .heart-icon {
          fill: currentColor;
          stroke: none;
        }
        .heart-btn {
          /* default: white translucent */
          background: rgba(255, 255, 255, 0.9);
          color: #820057;
          border: none;
        }
        .heart-btn:hover {
          background: #820057;
          color: #C9A84C;
        }
        /* Estudio cromático: estilos del botón de favoritos */
        .fav-style-glass .heart-btn {
          background: rgba(255, 255, 255, 0.35);
          border: 1px solid rgba(255, 255, 255, 0.55);
          backdrop-filter: blur(3px);
          color: #820057;
        }
        .fav-style-glass .heart-btn:hover {
          background: rgba(130, 0, 87, 0.85);
          border-color: rgba(130, 0, 87, 0.85);
          color: #C9A84C;
        }
        .fav-style-gold .heart-btn {
          background: #C9A84C;
          color: #820057;
          border: none;
        }
        .fav-style-gold .heart-btn:hover {
          background: #820057;
          color: #C9A84C;
        }
        .fav-style-purple .heart-btn {
          background: #820057;
          color: #C9A84C;
          border: none;
        }
        .fav-style-purple .heart-btn:hover {
          background: #C9A84C;
          color: #820057;
        }
        .fav-style-outline .heart-btn {
          background: transparent;
          border: 1.5px solid #820057;
          color: #820057;
        }
        .fav-style-outline .heart-btn:hover {
          background: #820057;
          color: #C9A84C;
          border-color: #820057;
        }
        .fav-style-clean .heart-btn {
          background: transparent;
          border: none;
          color: #820057;
        }
        .fav-style-clean .heart-btn:hover {
          background: #820057;
          color: #C9A84C;
        }
        .cat-card-img {
          transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1), filter 0.5s ease;
        }
        .cat-card:hover .cat-card-img {
          transform: scale(1.06);
          filter: brightness(1.04);
        }
        .cat-card-overlay {
          transition: opacity 0.5s ease;
        }
        .cat-card:hover .cat-card-overlay {
          opacity: 0.82;
        }
        section[id] { scroll-margin-top: 5rem; }
        
        /* Tipografías Dinámicas del Estudio (excluye iconos FontAwesome) */
        html.font-variant-classic *:not(.fa):not(.fas):not(.far):not(.fab):not(.fa-solid):not(.fa-regular):not(.fa-brands):not(.fa-light),
        html.font-variant-classic *:not(.fa):not(.fas):not(.far):not(.fab):not(.fa-solid):not(.fa-regular):not(.fa-brands):not(.fa-light)::before,
        html.font-variant-classic *:not(.fa):not(.fas):not(.far):not(.fab):not(.fa-solid):not(.fa-regular):not(.fa-brands):not(.fa-light)::after {
            font-family: 'Cormorant Garamond', serif;
        }
        
        /* Modificadores de tamaño dinámicos controlados por el Estudio */
        html.font-variant-classic.font-scale-standard p,
        html.font-variant-classic.font-scale-standard span:not(.fa),
        html.font-variant-classic.font-scale-standard a:not(.btn-gold):not(.btn-purple),
        html.font-variant-classic.font-scale-standard li,
        html.font-variant-classic.font-scale-standard td,
        html.font-variant-classic.font-scale-standard th {
            font-size: 1.02em;
            letter-spacing: 0.01em;
        }

        html.font-variant-classic.font-scale-medium p,
        html.font-variant-classic.font-scale-medium span:not(.fa),
        html.font-variant-classic.font-scale-medium a:not(.btn-gold):not(.btn-purple),
        html.font-variant-classic.font-scale-medium li,
        html.font-variant-classic.font-scale-medium td,
        html.font-variant-classic.font-scale-medium th {
            font-size: 1.09em; 
            letter-spacing: 0.015em;
        }

        html.font-variant-classic.font-scale-large p,
        html.font-variant-classic.font-scale-large span:not(.fa),
        html.font-variant-classic.font-scale-large a:not(.btn-gold):not(.btn-purple),
        html.font-variant-classic.font-scale-large li,
        html.font-variant-classic.font-scale-large td,
        html.font-variant-classic.font-scale-large th {
            font-size: 1.16em;
            letter-spacing: 0.02em;
        }

        html.font-variant-classic .font-sans,
        html.font-variant-classic .nav-link,
        html.font-variant-classic button,
        html.font-variant-classic input,
        html.font-variant-classic select,
        html.font-variant-classic textarea,
        html.font-variant-classic .btn-gold,
        html.font-variant-classic .btn-purple,
        html.font-variant-classic .section-tag { 
            font-family: 'Jost', sans-serif; 
        }

        html.font-variant-editorial *:not(.fa):not(.fas):not(.far):not(.fab):not(.fa-solid):not(.fa-regular):not(.fa-brands):not(.fa-light),
        html.font-variant-editorial *:not(.fa):not(.fas):not(.far):not(.fab):not(.fa-solid):not(.fa-regular):not(.fa-brands):not(.fa-light)::before,
        html.font-variant-editorial *:not(.fa):not(.fas):not(.far):not(.fab):not(.fa-solid):not(.fa-regular):not(.fa-brands):not(.fa-light)::after {
            font-family: 'Playfair Display', serif;
        }

        /* Escala en Montserrat */
        html.font-variant-editorial.font-scale-standard p,
        html.font-variant-editorial.font-scale-standard span:not(.fa),
        html.font-variant-editorial.font-scale-standard a:not(.btn-gold):not(.btn-purple),
        html.font-variant-editorial.font-scale-standard li,
        html.font-variant-editorial.font-scale-standard td,
        html.font-variant-editorial.font-scale-standard th {
            font-size: 0.95em;
        }

        html.font-variant-editorial.font-scale-medium p,
        html.font-variant-editorial.font-scale-medium span:not(.fa),
        html.font-variant-editorial.font-scale-medium a:not(.btn-gold):not(.btn-purple),
        html.font-variant-editorial.font-scale-medium li,
        html.font-variant-editorial.font-scale-medium td,
        html.font-variant-editorial.font-scale-medium th {
            font-size: 1.02em;
        }

        html.font-variant-editorial.font-scale-large p,
        html.font-variant-editorial.font-scale-large span:not(.fa),
        html.font-variant-editorial.font-scale-large a:not(.btn-gold):not(.btn-purple),
        html.font-variant-editorial.font-scale-large li,
        html.font-variant-editorial.font-scale-large td,
        html.font-variant-editorial.font-scale-large th {
            font-size: 1.09em;
        }

        html.font-variant-editorial .font-sans,
        html.font-variant-editorial .nav-link,
        html.font-variant-editorial button,
        html.font-variant-editorial input,
        html.font-variant-editorial select,
        html.font-variant-editorial textarea,
        html.font-variant-editorial .btn-gold,
        html.font-variant-editorial .btn-purple,
        html.font-variant-editorial .section-tag,
        html.font-variant-editorial p,
        html.font-variant-editorial span,
        html.font-variant-editorial div:not(.font-serif) { 
            font-family: 'Montserrat', sans-serif; 
        }
        html.font-variant-editorial .font-serif,
        html.font-variant-editorial h1,
        html.font-variant-editorial h2,
        html.font-variant-editorial h3,
        html.font-variant-editorial h4,
        html.font-variant-editorial em {
            font-family: 'Playfair Display', serif !important;
        }

        /* Excepción: iconos Font Awesome — usan su propia fuente de iconos */
        .fa, .fas, .far, .fal, .fab, .fa-solid, .fa-regular, .fa-brands,
        [class*=" fa-"], [class^="fa-"] { font-family: "Font Awesome 6 Free", "Font Awesome 6 Brands" !important; }
        .nav-link { position: relative; text-decoration: none !important; }
        .nav-link::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1px; background: #C9A84C; transition: width 0.3s ease; }
        .nav-link:hover::after { width: 100%; }
        .hero-overlay { background: linear-gradient(135deg, rgba(130,0,87,0.72) 0%, rgba(130,0,87,0.3) 60%, rgba(0,0,0,0.05) 100%); }
        .gold-line { background: linear-gradient(90deg, transparent, #C9A84C, transparent); }
        .btn-gold { background: #C9A84C; color: #820057; }
        .btn-gold:hover { background: #820057; color: #C9A84C; }
        .btn-purple { background: #820057; color: #C9A84C; }
        .btn-purple:hover { background: #C9A84C; color: #820057; }
        html.btn-text-white .btn-gold,
        html.btn-text-white .btn-gold:hover,
        html.btn-text-white .btn-purple,
        html.btn-text-white .btn-purple:hover {
          color: #ffffff !important;
        }
        html.btn-text-black .btn-gold,
        html.btn-text-black .btn-gold:hover,
        html.btn-text-black .btn-purple,
        html.btn-text-black .btn-purple:hover {
          color: #000000 !important;
        }
        .section-tag { letter-spacing: 0.25em; font-size: 0.7rem; text-transform: uppercase; color: #C9A84C; }
        .testimonial-card { border-left: 3px solid #C9A84C; }
        .logo-exclamation { color: #C9A84C; }
        a { text-decoration: none !important; }
    </style>
</head>
<body class="bg-cream text-gray-800 overflow-x-hidden w-full">
    <!-- Script inline de inicialización rápida de fuente y tamaño para evitar FOUC -->
    <script is:inline>
      (function() {
        var savedFont = localStorage.getItem('matizes_font_variant') || 'classic';
        var savedScale = localStorage.getItem('matizes_font_scale') || 'medium';
        var savedFavStyle = localStorage.getItem('matizes_fav_style') || 'white';
        var savedBtnText = localStorage.getItem('matizes_btn_text_color') || 'original';
        document.documentElement.classList.add('font-variant-' + savedFont);
        document.documentElement.classList.add('font-scale-' + savedScale);
        document.documentElement.classList.add('fav-style-' + savedFavStyle);
        document.documentElement.classList.add('btn-text-' + savedBtnText);
      })();
    </script>
    <!-- ===================== SPLASH SCREEN ===================== -->
    <style>
      /* --- Base --- */
      #splash-screen {
        background: #faf8f4;
        transition: transform 0.85s cubic-bezier(0.76, 0, 0.24, 1);
      }
      #splash-screen.splash-out {
        transform: translateY(-100%);
      }

      /* --- Logo entrance --- */
      @keyframes splashLogoIn {
        from { opacity: 0; transform: scale(0.88) translateY(18px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
      }
      #splash-logo {
        animation: splashLogoIn 1s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both;
      }

      /* --- Corner brackets draw in --- */
      @keyframes bracketTL {
        from { width: 0; height: 0; }
        to   { width: 2.5rem; height: 2.5rem; }
      }
      @keyframes bracketBR {
        from { width: 0; height: 0; }
        to   { width: 2.5rem; height: 2.5rem; }
      }
      .splash-corner {
        position: absolute;
        width: 0;
        height: 0;
        border-color: #C9A84C;
        border-style: solid;
        overflow: hidden;
        animation: bracketTL 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }
      .splash-corner-tl { top: 1.5rem; left: 1.5rem; border-width: 2px 0 0 2px; animation-delay: 0.1s; }
      .splash-corner-tr { top: 1.5rem; right: 1.5rem; border-width: 2px 2px 0 0; animation-delay: 0.2s; }
      .splash-corner-bl { bottom: 1.5rem; left: 1.5rem; border-width: 0 0 2px 2px; animation-delay: 0.3s; }
      .splash-corner-br { bottom: 1.5rem; right: 1.5rem; border-width: 0 2px 2px 0; animation-delay: 0.4s; }
      @media (min-width: 1024px) {
        .splash-corner-tl { top: 2rem; left: 2rem; }
        .splash-corner-tr { top: 2rem; right: 2rem; }
        .splash-corner-bl { bottom: 2rem; left: 2rem; }
        .splash-corner-br { bottom: 2rem; right: 2rem; }
        .splash-corner { animation-name: bracketBR; }
        @keyframes bracketBR {
          from { width: 0; height: 0; }
          to   { width: 3rem; height: 3rem; }
        }
      }

      /* --- Inner frame fade in --- */
      @keyframes splashFrameIn {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      #splash-inner-border {
        position: absolute;
        inset: 3.5rem;
        border: 1px solid rgba(201, 168, 76, 0.2);
        animation: splashFrameIn 0.8s ease 0.6s both;
        pointer-events: none;
      }

      /* --- Gold rule above/below logo --- */
      @keyframes splashLineGrow {
        from { transform: scaleX(0); opacity: 0; }
        to   { transform: scaleX(1); opacity: 1; }
      }
      .splash-line {
        display: block;
        width: 4rem;
        height: 1px;
        background: linear-gradient(90deg, transparent, #C9A84C, transparent);
        transform-origin: center;
        animation: splashLineGrow 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.9s both;
      }

      /* --- Hint text pulse --- */
      @keyframes splashPulse {
        0%, 100% { opacity: 0.35; }
        50%       { opacity: 0.85; }
      }
      #splash-hint {
        font-family: 'Jost', sans-serif;
        font-size: 0.6rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #820057;
        animation: splashFadeIn 0.6s ease 1.4s both, splashPulse 2s ease 2s infinite;
      }
      @keyframes splashFadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 0.35; transform: translateY(0); }
      }

      /* --- Progress bar --- */
      @keyframes splashProgress {
        from { transform: scaleX(0); }
        to   { transform: scaleX(1); }
      }
      #splash-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: #C9A84C;
        transform-origin: left center;
        transform: scaleX(0);
        animation: splashProgress 3s linear 0.3s forwards;
      }
    </style>

    <div id="splash-screen" aria-hidden="true" style="display:none" class="fixed inset-0 z-[9999] flex items-center justify-center cursor-pointer">
      <!-- Animated corner brackets -->
      <span class="splash-corner splash-corner-tl pointer-events-none"></span>
      <span class="splash-corner splash-corner-tr pointer-events-none"></span>
      <span class="splash-corner splash-corner-bl pointer-events-none"></span>
      <span class="splash-corner splash-corner-br pointer-events-none"></span>
      <!-- Inner frame -->
      <div id="splash-inner-border"></div>
      <!-- Progress bar -->
      <div id="splash-progress"></div>

      <!-- Logo + lines + hint -->
      <div class="relative z-10 flex flex-col items-center gap-4 text-[#820057]">
        <span class="splash-line"></span>
        <div id="splash-logo">
          <MatizesVertical class="h-[42vh] max-h-[380px] w-auto" />
        </div>
        <span class="splash-line"></span>
        <p id="splash-hint">Toca para continuar</p>
      </div>
    </div>
    <slot />
    <script>
      import '../scripts/cart';
      import '../scripts/favorites';
    </script>
    <script is:inline>
      (function () {
        try {
          if (sessionStorage.getItem('matizes_splash_shown') === '1') return;
          var el = document.getElementById('splash-screen');
          if (!el) return;
          el.style.display = 'flex';
          function dismiss() {
            if (el.dataset.dismissed) return;
            el.dataset.dismissed = '1';
            el.classList.add('splash-out');
            setTimeout(function () { el.remove(); }, 880);
            try { sessionStorage.setItem('matizes_splash_shown', '1'); } catch (e) {}
          }
          el.addEventListener('click', dismiss);
          setTimeout(dismiss, 3300);
        } catch (e) {}
      })();
    </script>

    <script is:inline>
      /* ---- Scroll-reveal IntersectionObserver ---- */
      (function () {
        if (!('IntersectionObserver' in window)) {
          /* Fallback: show everything immediately */
          document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale,.stagger-grid').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }

        var revealObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08 });

        document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale,.stagger-grid').forEach(function (el) {
          revealObs.observe(el);
        });
      })();

      /* ---- Stat / number counter ---- */
      (function () {
        var counterObs;
        var counters = document.querySelectorAll('[data-stat-target]');
        if (!counters.length) return;

        function animateCounter(el) {
          var target = parseFloat(el.dataset.statTarget);
          var duration = parseInt(el.dataset.statDuration || '1800', 10);
          var suffix = el.dataset.statSuffix || '';
          var decimals = el.dataset.statDecimals ? parseInt(el.dataset.statDecimals, 10) : 0;
          var start = null;

          function step(ts) {
            if (!start) start = ts;
            var progress = Math.min((ts - start) / duration, 1);
            /* easeOutExpo */
            var eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
            var current = eased * target;
            el.textContent = current.toFixed(decimals).replace('.', ',') + suffix;
            if (progress < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }

        if ('IntersectionObserver' in window) {
          counterObs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                animateCounter(entry.target);
                counterObs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.5 });
          counters.forEach(function (el) { counterObs.observe(el); });
        } else {
          counters.forEach(animateCounter);
        }
      })();
    </script>

    <!-- ===== TEMP: Color picker oro ===== -->
    <div id="color-picker-panel" style="
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 9998;
      background: #1a1a1a;
      border: 1px solid rgba(201,168,76,0.4);
      font-family: 'Jost', sans-serif;
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      min-width: 180px;
    ">
      <button id="color-picker-toggle" style="
        display:flex;align-items:center;justify-content:space-between;
        width:100%;padding:10px 14px;background:none;border:none;
        cursor:pointer;color:rgba(255,255,255,0.4);font-family:'Jost',sans-serif;
        font-size:9px;letter-spacing:0.2em;text-transform:uppercase;
      ">
        <span>Estudio cromático</span>
        <span id="color-picker-arrow" style="font-size:10px;transition:transform 0.2s">▲</span>
      </button>
      <div id="color-picker-body" style="padding:0 14px 12px;display:flex;flex-direction:column;gap:6px">
        <div style="display:flex;flex-direction:column;gap:6px" id="color-options">
          <!-- opciones inyectadas por JS -->
        </div>

        <div id="font-switch-section" style="border-top:1px solid rgba(255,255,255,0.1);margin-top:6px;padding-top:10px">
          <p style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin:0 0 6px">Tipografía</p>
          <div style="display:flex;gap:6px">
            <button id="font-variant-classic" data-font="classic" class="font-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Cormorant</button>
            <button id="font-variant-editorial" data-font="editorial" class="font-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Playfair</button>
          </div>
        </div>

        <div id="fav-style-section" style="border-top:1px solid rgba(255,255,255,0.1);margin-top:6px;padding-top:10px">
          <p style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin:0 0 6px">Botón favoritos</p>
          <div style="display:flex;gap:6px">
            <button id="fav-style-white" data-fav-style="white" class="fav-style-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Blanco</button>
            <button id="fav-style-glass" data-fav-style="glass" class="fav-style-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Cristal</button>
            <button id="fav-style-gold" data-fav-style="gold" class="fav-style-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Oro</button>
            <button id="fav-style-purple" data-fav-style="purple" class="fav-style-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Morado</button>
            <button id="fav-style-outline" data-fav-style="outline" class="fav-style-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Lineal</button>
            <button id="fav-style-clean" data-fav-style="clean" class="fav-style-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Limpio</button>
          </div>
        </div>

        <div id="scale-switch-section" style="border-top:1px solid rgba(255,255,255,0.1);margin-top:6px;padding-top:10px">
          <p style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin:0 0 6px">Escala de Texto</p>
          <div style="display:flex;gap:6px">
            <button id="scale-variant-standard" data-scale="standard" class="scale-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Normal</button>
            <button id="scale-variant-medium" data-scale="medium" class="scale-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">+8%</button>
            <button id="scale-variant-large" data-scale="large" class="scale-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">+15%</button>
          </div>
        </div>

        <div id="btn-text-color-section" style="border-top:1px solid rgba(255,255,255,0.1);margin-top:6px;padding-top:10px">
          <p style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin:0 0 6px">Texto de botones</p>
          <div style="display:flex;gap:6px">
            <button id="btn-text-original" data-text-color="original" class="btn-text-color-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Original</button>
            <button id="btn-text-white" data-text-color="white" class="btn-text-color-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Blanco</button>
            <button id="btn-text-black" data-text-color="black" class="btn-text-color-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Negro</button>
          </div>
        </div>
        
        <div id="hero-switch-section" style="border-top:1px solid rgba(255,255,255,0.1);margin-top:6px;padding-top:10px">
          <p style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin:0 0 6px">Diseño del hero</p>
          <div style="display:flex;gap:6px">
            <button id="hero-variant-classic" data-variant="classic" class="hero-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:'Jost',sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Clásico</button>
            <button id="hero-variant-stitch" data-variant="stitch" class="hero-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:'Jost',sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">Editorial</button>
            <button id="hero-variant-3d" data-variant="3d" class="hero-variant-btn" style="flex:1;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;font-family:'Jost',sans-serif;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6)">3D</button>
          </div>
        </div>
      </div>
    </div>
    <script is:inline>
      (function () {
        var GOLD_RGB = 'rgb(201,168,76)';
        var current = null;

        var options = [
          { id: 'gold',   color: '#C9A84C', label: 'Oro original'  },
          { id: 'sage',   color: '#8A9E7E', label: 'Verde salvia'  },
          { id: 'slate',  color: '#7A8FA6', label: 'Azul pizarra'  },
          { id: 'sand',   color: '#C4A882', label: 'Arena dorada'  },
          { id: 'rose',   color: '#C4828A', label: 'Rosa palo'     },
          { id: 'ivory',  color: '#F0EAD6', label: 'Marfil'        },
        ];

        function toRgbNorm(hex) {
          var r = parseInt(hex.slice(1,3),16);
          var g = parseInt(hex.slice(3,5),16);
          var b = parseInt(hex.slice(5,7),16);
          return 'rgb(' + r + ',' + g + ',' + b + ')';
        }

        function colorsMatch(a, b) {
          return a.replace(/\s/g,'') === b.replace(/\s/g,'');
        }

        function applyColor(targetHex) {
          var fromRgb = current ? toRgbNorm(current) : GOLD_RGB;
          document.querySelectorAll('.btn-gold, .btn-purple').forEach(function (el) {
            var cs = window.getComputedStyle(el);
            ['color','background-color','border-top-color','border-bottom-color','border-left-color','border-right-color'].forEach(function (prop) {
              var val = cs.getPropertyValue(prop).replace(/\s/g,'');
              if (colorsMatch(val, fromRgb)) {
                el.style.setProperty(prop, targetHex, 'important');
              }
            });
          });
          current = targetHex;
        }

        /* Collapse / expand */
        var toggleBtn = document.getElementById('color-picker-toggle');
        var body = document.getElementById('color-picker-body');
        var arrow = document.getElementById('color-picker-arrow');
        var collapsed = false;
        toggleBtn.addEventListener('click', function () {
          collapsed = !collapsed;
          body.style.display = collapsed ? 'none' : 'flex';
          arrow.style.transform = collapsed ? 'rotate(180deg)' : 'rotate(0deg)';
        });

        /* Build UI */
        var container = document.getElementById('color-options');
        options.forEach(function (opt) {
          var row = document.createElement('button');
          row.style.cssText = 'display:flex;align-items:center;gap:8px;background:none;border:1px solid rgba(255,255,255,0.08);padding:6px 8px;cursor:pointer;width:100%;text-align:left;transition:border-color 0.2s';
          row.innerHTML =
            '<span style="width:14px;height:14px;border-radius:50%;background:' + opt.color + ';flex-shrink:0;border:1px solid rgba(255,255,255,0.15)"></span>' +
            '<span style="font-family:sans-serif;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.6)">' + opt.label + '</span>';
          row.dataset.colorId = opt.id;
          row.addEventListener('mouseenter', function () { row.style.borderColor = 'rgba(201,168,76,0.5)'; });
          row.addEventListener('mouseleave', function () { row.style.borderColor = 'rgba(255,255,255,0.08)'; });
          row.addEventListener('click', function () {
            applyColor(opt.color);
            /* mark active */
            container.querySelectorAll('button').forEach(function (b) {
              b.style.borderColor = 'rgba(255,255,255,0.08)';
            });
            row.style.borderColor = opt.color;
          });
          container.appendChild(row);
        });

        /* ---- Tipografía switch ---- */
        var fontBtns = document.querySelectorAll('.font-variant-btn');
        function markActiveFont(font) {
          fontBtns.forEach(function (b) {
            var active = b.dataset.font === font;
            b.style.borderColor = active ? '#C9A84C' : 'rgba(255,255,255,0.08)';
            b.style.color = active ? '#C9A84C' : 'rgba(255,255,255,0.6)';
          });
          document.documentElement.classList.remove('font-variant-classic', 'font-variant-editorial');
          document.documentElement.classList.add('font-variant-' + font);
        }

        var savedFont = 'classic';
        try { savedFont = localStorage.getItem('matizes_font_variant') || 'classic'; } catch (e) {}
        markActiveFont(savedFont);

        fontBtns.forEach(function (b) {
          b.addEventListener('click', function () {
            var f = b.dataset.font;
            try { localStorage.setItem('matizes_font_variant', f); } catch (e) {}
            markActiveFont(f);
          });
        });

        /* ---- Favorite button style switch ---- */
        var favStyleBtns = document.querySelectorAll('.fav-style-btn');
        function markActiveFavStyle(style) {
          favStyleBtns.forEach(function (b) {
            var active = b.dataset.favStyle === style;
            b.style.borderColor = active ? '#C9A84C' : 'rgba(255,255,255,0.08)';
            b.style.color = active ? '#C9A84C' : 'rgba(255,255,255,0.6)';
          });
          document.documentElement.classList.remove('fav-style-white', 'fav-style-glass', 'fav-style-gold', 'fav-style-purple', 'fav-style-outline', 'fav-style-clean');
          document.documentElement.classList.add('fav-style-' + style);
        }

        var savedFavStyle = 'white';
        try { savedFavStyle = localStorage.getItem('matizes_fav_style') || 'white'; } catch (e) {}
        markActiveFavStyle(savedFavStyle);

        favStyleBtns.forEach(function (b) {
          b.addEventListener('click', function () {
            var s = b.dataset.favStyle;
            try { localStorage.setItem('matizes_fav_style', s); } catch (e) {}
            markActiveFavStyle(s);
          });
        });

        /* ---- Escala de Texto switch ---- */
        var scaleBtns = document.querySelectorAll('.scale-variant-btn');
        function markActiveScale(scale) {
          scaleBtns.forEach(function (b) {
            var active = b.dataset.scale === scale;
            b.style.borderColor = active ? '#C9A84C' : 'rgba(255,255,255,0.08)';
            b.style.color = active ? '#C9A84C' : 'rgba(255,255,255,0.6)';
          });
          document.documentElement.classList.remove('font-scale-standard', 'font-scale-medium', 'font-scale-large');
          document.documentElement.classList.add('font-scale-' + scale);
        }

        var savedScale = 'medium';
        try { savedScale = localStorage.getItem('matizes_font_scale') || 'medium'; } catch (e) {}
        markActiveScale(savedScale);

        scaleBtns.forEach(function (b) {
          b.addEventListener('click', function () {
            var s = b.dataset.scale;
            try { localStorage.setItem('matizes_font_scale', s); } catch (e) {}
            markActiveScale(s);
          });
        });

        /* ---- Button text color switch ---- */
        var btnTextBtns = document.querySelectorAll('.btn-text-color-btn');
        function markActiveBtnText(color) {
          btnTextBtns.forEach(function (b) {
            var active = b.dataset.textColor === color;
            b.style.borderColor = active ? '#C9A84C' : 'rgba(255,255,255,0.08)';
            b.style.color = active ? '#C9A84C' : 'rgba(255,255,255,0.6)';
          });
          document.documentElement.classList.remove('btn-text-original', 'btn-text-white', 'btn-text-black');
          document.documentElement.classList.add('btn-text-' + color);
        }

        var savedBtnText = 'original';
        try { savedBtnText = localStorage.getItem('matizes_btn_text_color') || 'original'; } catch (e) {}
        markActiveBtnText(savedBtnText);

        btnTextBtns.forEach(function (b) {
          b.addEventListener('click', function () {
            var c = b.dataset.textColor;
            try { localStorage.setItem('matizes_btn_text_color', c); } catch (e) {}
            markActiveBtnText(c);
          });
        });

        /* ---- Hero variant switch (solo si la página tiene algún hero) ---- */
        var section = document.getElementById('hero-switch-section');
        if (section) {
          var hasHero = document.getElementById('hero') || document.getElementById('hero-stitch') || document.getElementById('hero-3d');
          if (hasHero) {
            section.style.setProperty('display', 'block', 'important');
            var btns = section.querySelectorAll('.hero-variant-btn');
 
            function markActive(variant) {
              btns.forEach(function (b) {
                var active = b.dataset.variant === variant;
                b.style.borderColor = active ? '#C9A84C' : 'rgba(255,255,255,0.08)';
                b.style.color = active ? '#C9A84C' : 'rgba(255,255,255,0.6)';
              });
            }
 
            var savedVariant = 'classic';
            try { savedVariant = localStorage.getItem('matizes_hero_variant') || 'classic'; } catch (e) {}
            markActive(savedVariant);
 
            btns.forEach(function (b) {
              b.addEventListener('click', function () {
                var v = b.dataset.variant;
                try { localStorage.setItem('matizes_hero_variant', v); } catch (e) {}
                markActive(v);
                document.dispatchEvent(new CustomEvent('hero:variant', { detail: v }));
              });
            });
          } else {
            section.style.setProperty('display', 'none', 'important');
          }
        }
      })();
    </script>
    <!-- ===== /TEMP ===== -->
</body>
</html>
