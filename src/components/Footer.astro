---
import MatizesWordmark from './MatizesWordmark.astro';
---

<footer id="footer" class="bg-gray-900 text-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12 mb-12">
      <div class="lg:col-span-2">
        <a href="/" aria-label="Matizes" class="inline-block mb-5 text-white hover:text-gold transition-colors">
          <MatizesWordmark class="h-7 w-auto" />
        </a>
        <p class="text-gray-400 font-light leading-relaxed mb-6 max-w-xs">Pastelería fina artesanal. Cada creación es una experiencia de sabor, textura y elegancia.</p>
        <div class="flex gap-4">
          <a href="#" aria-label="Instagram de Mat!zes" class="w-9 h-9 border border-white/20 flex items-center justify-center text-gray-400 hover:border-gold hover:text-gold transition-colors">
            <i class="fa-brands fa-instagram text-sm"></i>
          </a>
          <a href="#" aria-label="Facebook de Mat!zes" class="w-9 h-9 border border-white/20 flex items-center justify-center text-gray-400 hover:border-gold hover:text-gold transition-colors">
            <i class="fa-brands fa-facebook-f text-sm"></i>
          </a>
          <a href="#" aria-label="TikTok de Mat!zes" class="w-9 h-9 border border-white/20 flex items-center justify-center text-gray-400 hover:border-gold hover:text-gold transition-colors">
            <i class="fa-brands fa-tiktok text-sm"></i>
          </a>
          <a href="#" aria-label="WhatsApp de Mat!zes" class="w-9 h-9 border border-white/20 flex items-center justify-center text-gray-400 hover:border-gold hover:text-gold transition-colors">
            <i class="fa-brands fa-whatsapp text-sm"></i>
          </a>
        </div>
      </div>
      <div>
        <h4 class="text-xs tracking-widest uppercase text-gold mb-5 font-medium">Navegación</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-gray-400 hover:text-gold text-sm font-light transition-colors">Inicio</a></li>
          <li><a href="/menu" class="text-gray-400 hover:text-gold text-sm font-light transition-colors">Menú</a></li>
          <li><a href="/blog" class="text-gray-400 hover:text-gold text-sm font-light transition-colors">Blog</a></li>
          <li><a href="/contacto" class="text-gray-400 hover:text-gold text-sm font-light transition-colors">Contacto</a></li>
          <li><a href="/carrito" class="text-gray-400 hover:text-gold text-sm font-light transition-colors">Carrito</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs tracking-widest uppercase text-gold mb-5 font-medium">Contacto</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-gray-400 text-sm font-light">
            <i class="fa-solid fa-location-dot text-gold mt-0.5 text-xs"></i>
            <span>Calle Gran Vía 47, 3º,<br/>28013 Madrid</span>
          </li>
          <li class="flex items-center gap-3 text-gray-400 text-sm font-light">
            <i class="fa-solid fa-phone text-gold text-xs"></i>
            <span>+34 91 234 56 78</span>
          </li>
          <li class="flex items-center gap-3 text-gray-400 text-sm font-light">
            <i class="fa-solid fa-envelope text-gold text-xs"></i>
            <span>hola@matizes.es</span>
          </li>
          <li class="flex items-center gap-3 text-gray-400 text-sm font-light">
            <i class="fa-solid fa-clock text-gold text-xs"></i>
            <span>Mar–Dom: 9:00 – 20:00</span>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-600 text-xs tracking-wide flex items-center gap-1.5">© 2026 <MatizesWordmark class="inline-block h-3 w-auto align-middle" /> Pastelería Fina. Todos los derechos reservados.</p>
      <div class="flex gap-6">
        <a href="#" aria-label="Política de Privacidad (próximamente)" class="text-gray-600 hover:text-gold text-xs tracking-wide transition-colors">Política de Privacidad</a>
        <a href="#" aria-label="Aviso Legal (próximamente)" class="text-gray-600 hover:text-gold text-xs tracking-wide transition-colors">Aviso Legal</a>
      </div>
    </div>
  </div>
</footer>
