---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import { getSimilarProducts } from '../data/products';

const shipping = 4.90;

const recommended = getSimilarProducts(['tiramisu-revisitado', 'creme-brulee', 'panna-cotta-rosa', 'fraisier-temporada']);

const features = [
  { icon: 'fa-truck-fast', title: 'Entrega el mismo día', text: 'Pedidos antes de las 12:00h' },
  { icon: 'fa-lock', title: 'Pago seguro', text: 'Encriptación SSL' },
  { icon: 'fa-leaf', title: 'Ingredientes naturales', text: 'Sin conservadores' },
  { icon: 'fa-award', title: 'Elaboración artesanal', text: 'Calidad garantizada' },
];
---

<Layout title="Tu Carrito | Mat!zes">
  <Header />

  <!-- Spacer for fixed header -->
  <div class="h-16 lg:h-20"></div>

  <!-- HERO -->
  <section class="py-12 lg:py-16 bg-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-4 mb-8">
        <div>
          <p class="section-tag mb-4">Tu selección</p>
          <h1 class="font-serif text-4xl lg:text-6xl font-light text-purple">Carrito de <em class="italic text-gold">Compras</em></h1>
        </div>
        <div class="flex items-center gap-2 text-sm text-gray-500">
          <i class="fa-solid fa-circle text-gold text-[7px]"></i>
          <span><span id="cart-items-count">0</span> artículos en tu carrito</span>
        </div>
      </div>
      <div class="gold-line h-px w-full"></div>
    </div>
  </section>

  <!-- CART -->
  <section class="pb-16 lg:pb-24 bg-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <!-- Empty state -->
      <div id="cart-empty" class="hidden text-center py-20">
        <div class="w-16 h-16 bg-gold/15 flex items-center justify-center mx-auto mb-6"><i class="fa-solid fa-bag-shopping text-gold text-2xl"></i></div>
        <h2 class="font-serif text-3xl text-purple font-light mb-3">Tu carrito está vacío</h2>
        <p class="text-gray-500 text-sm mb-8">Descubre nuestras creaciones y añade tus favoritas.</p>
        <a href="/menu" class="btn-purple inline-flex items-center gap-3 px-10 py-3.5 font-medium text-sm tracking-widest uppercase">
          Explorar el menú <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>

      <div id="cart-main" class="grid lg:grid-cols-3 gap-8">
        <!-- Items -->
        <div class="lg:col-span-2">
          <!-- Table header -->
          <div class="hidden md:grid grid-cols-12 gap-4 pb-4 border-b border-purple/15 text-xs tracking-widest uppercase text-gray-400">
            <div class="col-span-6">Producto</div>
            <div class="col-span-2 text-right">Precio</div>
            <div class="col-span-2 text-center">Cantidad</div>
            <div class="col-span-2 text-right">Subtotal</div>
          </div>

          <!-- Rows (rendered by JS) -->
          <div id="cart-items"></div>

          <!-- Actions -->
          <div class="flex items-center justify-between mt-6">
            <a href="/menu" class="inline-flex items-center gap-2 text-purple text-sm font-medium tracking-widest uppercase hover:text-gold transition-colors">
              <i class="fa-solid fa-arrow-left text-xs"></i> Continuar comprando
            </a>
            <button id="clear-cart" class="inline-flex items-center gap-2 text-gray-400 text-sm hover:text-purple transition-colors">
              <i class="fa-solid fa-trash-can text-xs"></i> Vaciar carrito
            </button>
          </div>

          <!-- Special note -->
          <div class="bg-white p-6 mt-8">
            <p class="text-xs tracking-widest uppercase text-purple mb-3 flex items-center gap-2"><i class="fa-regular fa-note-sticky text-gold"></i> Nota especial para tu pedido</p>
            <textarea rows="3" placeholder="¿Alguna dedicatoria, alergia o instrucción especial? Escríbelo aquí." class="w-full bg-cream-dark px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-gold resize-none"></textarea>
          </div>
        </div>

        <!-- Summary -->
        <div>
          <div class="bg-white p-8 sticky top-24">
            <h2 class="font-serif text-2xl text-purple mb-6">Resumen del <em class="italic text-gold">Pedido</em></h2>

            <ul id="summary-lines" class="space-y-3 pb-5 border-b border-purple/10"></ul>

            <div class="flex justify-between py-4 text-sm border-b border-purple/10">
              <span class="text-purple font-medium">Subtotal</span>
              <span id="summary-subtotal" class="text-purple font-medium">0,00 €</span>
            </div>

            <!-- Discount -->
            <div class="py-5 border-b border-purple/10">
              <p class="text-xs tracking-widest uppercase text-gray-400 mb-2">Código de descuento</p>
              <div class="flex gap-2">
                <input type="text" placeholder="MATIZES10" class="flex-1 bg-cream-dark px-4 py-2.5 text-sm focus:outline-none focus:ring-1 focus:ring-gold" />
                <button class="btn-gold px-5 py-2.5 text-xs font-medium tracking-widest uppercase">Aplicar</button>
              </div>
            </div>

            <div class="flex justify-between py-4 text-sm border-b border-gold/30">
              <span class="text-gray-500 flex items-center gap-2"><i class="fa-solid fa-truck text-gold text-xs"></i> Envío</span>
              <span id="summary-shipping" class="text-purple font-medium">{shipping.toFixed(2).replace('.', ',')} €</span>
            </div>

            <div class="flex justify-between items-center py-5">
              <span class="font-serif text-xl text-purple">Total</span>
              <span id="summary-total" class="font-serif text-3xl text-gold">0,00 €</span>
            </div>
            <p class="text-xs text-gray-400 mb-5">IVA incluido. Entrega el mismo día para pedidos antes de las 12:00h.</p>

            <a href="#" class="btn-purple w-full py-4 text-sm font-medium tracking-widest uppercase flex items-center justify-center gap-2">
              <i class="fa-solid fa-lock text-xs"></i> Proceder al pago
            </a>

            <div class="flex items-center justify-center gap-3 mt-5 text-gray-300 text-xl">
              <i class="fa-brands fa-cc-visa"></i>
              <i class="fa-brands fa-cc-mastercard"></i>
              <i class="fa-brands fa-cc-amex"></i>
              <i class="fa-brands fa-cc-paypal"></i>
            </div>
            <p class="text-center text-xs text-gray-400 mt-3 flex items-center justify-center gap-2"><i class="fa-solid fa-shield-halved text-gold"></i> Pago 100% seguro y encriptado</p>
          </div>

          <div class="bg-cream-dark p-5 mt-6 flex items-start gap-3">
            <i class="fa-solid fa-circle-check text-gold mt-0.5"></i>
            <div>
              <p class="text-sm font-medium text-purple">Entrega hoy disponible</p>
              <p class="text-xs text-gray-500">Pedido antes de las 12:00h · Madrid</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust features -->
  <section class="py-10 bg-cream-dark border-y border-gold/15">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        {features.map((f) => (
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 bg-gold/15 flex items-center justify-center mb-3"><i class={`fa-solid ${f.icon} text-gold`}></i></div>
            <p class="text-sm font-medium text-purple">{f.title}</p>
            <p class="text-xs text-gray-400">{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recommended -->
  {recommended.length > 0 && (
    <section class="py-16 lg:py-24 bg-cream">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
          <div>
            <p class="section-tag mb-4">Complementa tu pedido</p>
            <h2 class="font-serif text-4xl lg:text-5xl font-light text-purple">También te puede <em class="italic text-gold">gustar</em></h2>
          </div>
          <a href="/" class="inline-flex items-center gap-2 text-purple font-medium text-xs tracking-widest uppercase border-b border-purple pb-1 hover:text-gold hover:border-gold transition-colors self-start md:self-auto">
            Ver todo el menú <i class="fa-solid fa-arrow-right text-xs"></i>
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {recommended.map((p) => (<ProductCard product={p} />))}
        </div>
      </div>
    </section>
  )}

  <Footer />

  <script>
    import Cart from '../scripts/cart';

    const SHIPPING = 4.90;
    const fmt = (n: number) => n.toFixed(2).replace('.', ',');
    const esc = (s: string) => (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    function rowHtml(item: import('../scripts/cart').CartItem): string {
      const href = `/productos/${item.id}`;
      const size = item.size ? `<p class="text-xs text-gray-400 mt-0.5">${esc(item.size)}</p>` : '';
      return `
        <div class="grid grid-cols-12 gap-4 items-center py-6 border-b border-purple/10">
          <div class="col-span-12 md:col-span-6 flex gap-4">
            <a href="${href}" class="shrink-0"><img class="w-20 h-20 object-cover" src="${esc(item.image)}" alt="${esc(item.name)}" /></a>
            <div>
              <p class="text-xs tracking-widest uppercase text-gold mb-1">${esc(item.category || '')}</p>
              <a href="${href}" class="font-serif text-lg text-purple hover:text-gold transition-colors">${esc(item.name)}</a>
              ${size}
              <div class="flex items-center gap-4 mt-2 text-xs">
                <button class="cart-remove text-gray-400 hover:text-purple transition-colors flex items-center gap-1" data-id="${esc(item.id)}" data-size="${esc(item.size || '')}"><i class="fa-solid fa-trash-can"></i> Eliminar</button>
              </div>
            </div>
          </div>
          <div class="col-span-4 md:col-span-2 text-left md:text-right text-gray-600">${fmt(item.price)} €</div>
          <div class="col-span-4 md:col-span-2 flex justify-center">
            <div class="flex items-center border border-purple/20">
              <button class="qty-minus px-3 py-2 text-purple hover:bg-purple hover:text-gold transition-colors" data-id="${esc(item.id)}" data-size="${esc(item.size || '')}"><i class="fas fa-minus text-xs"></i></button>
              <span class="w-10 text-center py-2 border-x border-purple/20 text-sm">${item.qty}</span>
              <button class="qty-plus px-3 py-2 text-purple hover:bg-purple hover:text-gold transition-colors" data-id="${esc(item.id)}" data-size="${esc(item.size || '')}"><i class="fas fa-plus text-xs"></i></button>
            </div>
          </div>
          <div class="col-span-4 md:col-span-2 text-right font-serif text-lg text-purple">${fmt(item.price * item.qty)} €</div>
        </div>`;
    }

    function render(): void {
      const items = Cart.items();
      const main = document.getElementById('cart-main');
      const empty = document.getElementById('cart-empty');
      const countEl = document.getElementById('cart-items-count');
      if (countEl) countEl.textContent = String(Cart.count());

      if (!main || !empty) return;
      if (items.length === 0) {
        main.classList.add('hidden');
        empty.classList.remove('hidden');
        return;
      }
      main.classList.remove('hidden');
      empty.classList.add('hidden');

      const itemsEl = document.getElementById('cart-items');
      if (itemsEl) itemsEl.innerHTML = items.map(rowHtml).join('');

      const linesEl = document.getElementById('summary-lines');
      if (linesEl) linesEl.innerHTML = items.map((it) => `
        <li class="flex justify-between text-sm">
          <span class="text-gray-500">${esc(it.name)} × ${it.qty}</span>
          <span class="text-purple font-medium">${fmt(it.price * it.qty)} €</span>
        </li>`).join('');

      const subtotal = Cart.subtotal();
      const subEl = document.getElementById('summary-subtotal');
      const totalEl = document.getElementById('summary-total');
      if (subEl) subEl.textContent = fmt(subtotal) + ' €';
      if (totalEl) totalEl.textContent = fmt(subtotal + SHIPPING) + ' €';
    }

    document.addEventListener('DOMContentLoaded', () => {
      render();
      document.addEventListener('cart:updated', render);

      document.getElementById('cart-items')?.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const btn = target.closest<HTMLElement>('.qty-minus, .qty-plus, .cart-remove');
        if (!btn) return;
        const id = btn.dataset.id || '';
        const size = btn.dataset.size || '';
        const current = Cart.items().find((i) => i.id === id && (i.size || '') === size);
        if (!current) return;
        if (btn.classList.contains('qty-minus')) Cart.setQty(id, size, current.qty - 1);
        else if (btn.classList.contains('qty-plus')) Cart.setQty(id, size, current.qty + 1);
        else Cart.remove(id, size);
      });

      document.getElementById('clear-cart')?.addEventListener('click', () => Cart.clear());
    });
  </script>
</Layout>
