---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Página no encontrada | Mat!zes" description="Página no encontrada. Vuelve al inicio o explora el menú de pastelería artesanal Mat!zes." ogUrl="https://matizes.es/404">
  <Header />

  <div class="h-16 lg:h-20"></div>

  <section class="min-h-[calc(100vh-5rem)] bg-purple relative overflow-hidden flex items-center">
    <!-- Decorative circles -->
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full border border-gold" style="transform: translate(30%, -30%)"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full border border-gold" style="transform: translate(-30%, 30%)"></div>
    </div>

    <div class="relative z-10 w-full max-w-4xl mx-auto px-6 lg:px-10 py-20 text-center">
      <div class="reveal">

        <!-- 404 + heading stacked, no overlap -->
        <p class="font-serif text-[100px] lg:text-[140px] font-light leading-none text-white/10 select-none tracking-widest mb-2" aria-hidden="true">404</p>
        <h1 class="font-serif text-4xl lg:text-6xl font-light text-white mb-6">
          Esta página <em class="italic text-gold">no existe</em>
        </h1>

        <div class="gold-line h-px w-16 mx-auto mb-8"></div>

        <p class="text-white/60 font-light leading-relaxed text-lg max-w-lg mx-auto mb-12">
          Puede que el enlace haya cambiado o que hayas escrito mal la dirección.<br class="hidden sm:block" />
          En Mat!zes siempre hay algo bueno esperándote.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
          <a href="/" class="btn-gold inline-flex items-center gap-3 px-8 py-3.5 font-medium text-sm tracking-widest uppercase">
            <i class="fa-solid fa-house text-xs"></i> Volver al inicio
          </a>
          <a href="/menu" class="inline-flex items-center gap-3 px-8 py-3.5 border border-white/30 text-white font-medium text-sm tracking-widest uppercase hover:border-gold hover:text-gold transition-colors">
            <i class="fa-solid fa-utensils text-xs"></i> Ver el menú
          </a>
        </div>

        <!-- Quick links -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-lg mx-auto">
          {[
            { href: '/menu',     icon: 'fa-utensils',    label: 'Menú' },
            { href: '/blog',     icon: 'fa-newspaper',   label: 'Blog' },
            { href: '/contacto', icon: 'fa-envelope',    label: 'Contacto' },
            { href: '/carrito',  icon: 'fa-bag-shopping',label: 'Carrito' },
          ].map(link => (
            <a href={link.href} class="flex flex-col items-center gap-2 py-4 px-3 border border-white/10 text-white/50 hover:border-gold/50 hover:text-gold transition-colors">
              <i class={`fa-solid ${link.icon} text-gold/70 text-sm`}></i>
              <span class="text-xs tracking-widest uppercase">{link.label}</span>
            </a>
          ))}
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>
