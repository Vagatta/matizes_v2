---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Página no encontrada | Mat!zes">
  <Header />

  <div class="h-16 lg:h-20"></div>

  <section class="min-h-[70vh] bg-cream flex items-center">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Text -->
        <div class="reveal">
          <p class="section-tag mb-6">Error 404</p>
          <h1 class="font-serif text-6xl lg:text-8xl font-light text-purple leading-none mb-4">
            Oops,<br/><em class="italic text-gold">esta página</em><br/>no existe.
          </h1>
          <div class="gold-line h-px w-16 my-8"></div>
          <p class="text-gray-500 font-light leading-relaxed text-lg mb-10 max-w-md">
            Puede que el enlace haya cambiado o que hayas escrito mal la dirección. Pero no te preocupes — en Mat!zes siempre hay algo bueno esperándote.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/" class="btn-purple inline-flex items-center gap-3 px-8 py-3.5 font-medium text-sm tracking-widest uppercase">
              <i class="fa-solid fa-house text-xs"></i> Volver al inicio
            </a>
            <a href="/menu" class="btn-gold inline-flex items-center gap-3 px-8 py-3.5 font-medium text-sm tracking-widest uppercase">
              <i class="fa-solid fa-utensils text-xs"></i> Ver el menú
            </a>
          </div>
        </div>

        <!-- Visual -->
        <div class="reveal flex flex-col items-center justify-center text-center">
          <div class="relative">
            <div class="font-serif text-[180px] lg:text-[240px] font-light text-purple/8 leading-none select-none">
              404
            </div>
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
              <div class="w-24 h-24 bg-purple flex items-center justify-center">
                <i class="fa-solid fa-cake-candles text-gold text-3xl"></i>
              </div>
              <p class="font-serif text-xl text-purple font-light italic">La receta no se encontró</p>
            </div>
          </div>
          <!-- Quick links -->
          <div class="mt-8 grid grid-cols-2 gap-3 w-full max-w-xs">
            {[
              { href: '/menu', icon: 'fa-utensils', label: 'Menú' },
              { href: '/blog', icon: 'fa-newspaper', label: 'Blog' },
              { href: '/contacto', icon: 'fa-envelope', label: 'Contacto' },
              { href: '/carrito', icon: 'fa-bag-shopping', label: 'Carrito' },
            ].map(link => (
              <a href={link.href} class="flex items-center gap-3 bg-white p-4 text-sm text-purple hover:text-gold hover:border-gold border border-transparent transition-colors">
                <i class={`fa-solid ${link.icon} text-gold text-xs`}></i>
                <span class="font-medium tracking-widest uppercase text-xs">{link.label}</span>
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>
