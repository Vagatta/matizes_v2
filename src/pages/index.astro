---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProductCard from "../components/ProductCard.astro";
import MatizesWordmark from "../components/MatizesWordmark.astro";
import { products } from "../data/products";

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Mat!zes Pastelería Fina",
  image:
    "https://storage.googleapis.com/uxpilot-auth.appspot.com/3fd9c28d4d-cd1f86b109f2f92c0c84.png",
  url: "https://matizes.es/",
  telephone: "+34 91 234 56 78",
  email: "hola@matizes.es",
  priceRange: "€€",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Calle Gran Vía 47, 3º",
    addressLocality: "Madrid",
    postalCode: "28013",
    addressCountry: "ES",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 40.4196,
    longitude: -3.7016,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "20:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: "09:00",
      closes: "21:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Sunday",
      opens: "10:00",
      closes: "18:00",
    },
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.9",
    reviewCount: 120,
    bestRating: "5",
    worstRating: "1",
  },
  review: [
    {
      "@type": "Review",
      author: { "@type": "Person", name: "Laura M." },
      reviewRating: { "@type": "Rating", ratingValue: "5" },
      reviewBody:
        "Encargamos la tarta nupcial con 6 semanas de antelación. El resultado fue impresionante: tres pisos con flores naturales y un fraisier como relleno que hizo llorar a mi madre de emoción.",
      publisher: { "@type": "Organization", name: "Google" },
    },
    {
      "@type": "Review",
      author: { "@type": "Person", name: "Javier R." },
      reviewRating: { "@type": "Rating", ratingValue: "5" },
      reviewBody:
        "Llevo dos años viniendo cada sábado por los croissants. Son los mejores que he comido fuera de París, sin exagerar. El kouign-amann de los domingos es adictivo.",
      publisher: { "@type": "Organization", name: "Google" },
    },
    {
      "@type": "Review",
      author: { "@type": "Person", name: "Carmen R." },
      reviewRating: { "@type": "Rating", ratingValue: "5" },
      reviewBody:
        "Contratamos el catering dulce para una presentación de empresa con 90 personas. La bandeja de petit fours fue el tema de conversación de la tarde.",
      publisher: { "@type": "Organization", name: "Google" },
    },
  ],
};
---

<Layout
  title="Mat!zes — Pastelería Fina Artesanal"
  description="Pastelería fina artesanal en Valladolid. Creaciones de autor, tartas, cheesecakes, viennoiserie y regalos dulces elaborados con ingredientes selectos."
  ogUrl="https://matizes.es/"
>
  <Header />

  <!-- HERO SECTION -->
  <section
    id="hero"
    class="relative h-[700px] lg:h-[830px] flex items-center overflow-hidden mt-16 lg:mt-20"
  >
    <div class="absolute inset-0 overflow-hidden">
      <img
        id="hero-parallax-img"
        class="w-full h-[120%] object-cover object-center absolute top-[-10%] left-0"
        src="https://storage.googleapis.com/uxpilot-auth.appspot.com/3fd9c28d4d-cd1f86b109f2f92c0c84.png"
        alt="elegant pastry shop interior, fine patisserie, macarons and cakes on display, warm golden lighting, luxurious ambiance, editorial photography"
      />
    </div>
    <div class="hero-overlay absolute inset-0"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 w-full">
      <div class="max-w-xl lg:max-w-2xl hero-animate">
        <h1
          class="font-serif text-5xl lg:text-7xl xl:text-8xl font-light text-white leading-tight mb-4 lg:mb-6"
        >
          El arte en<br />
          <em class="italic text-gold">cada bocado</em>
        </h1>
        <div class="gold-line h-px w-24 mb-6 lg:mb-8"></div>
        <p
          class="text-white/80 font-light text-base lg:text-lg leading-relaxed mb-8 lg:mb-10 max-w-md"
        >
          Creaciones de pastelería fina elaboradas con ingredientes selectos.
          Cada pieza es una obra de sabor, textura y elegancia.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/menu"
            class="btn-gold inline-flex items-center justify-center gap-3 px-8 py-3.5 font-medium text-sm tracking-widest uppercase rounded-none"
          >
            <i class="fa-solid fa-utensils text-xs"></i>
            Explorar Menú
          </a>
          <a
            href="#featured-products"
            class="inline-flex items-center justify-center gap-3 px-8 py-3.5 border border-white/80 bg-white/10 text-white font-medium text-sm tracking-widest uppercase rounded-none hover:bg-gold/15 hover:border-gold hover:text-gold transition-colors"
          >
            Nuestras Creaciones
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
  </section>

  <!-- HERO SECTION — VARIANTE STITCH (Artisanal Nuance) -->
  <section
    id="hero-stitch"
    class="relative min-h-[100dvh] hidden flex-col justify-center overflow-hidden pt-16 lg:pt-20"
    style="background: #fff8f5;"
  >
    <!-- ── MÓVIL: texto arriba centrado + imágenes apiladas + CTA abajo ── -->
    <div
      class="lg:hidden flex flex-col items-center px-6 py-10 min-h-[calc(100dvh-4rem)]"
    >
      <!-- Texto -->
      <div class="stitch-text text-center mb-10 mt-4">
        <div class="flex items-center justify-center gap-3 mb-6">
          <div class="h-px w-10 bg-[#C9A84C]"></div>
          <div class="w-1.5 h-1.5 rotate-45 bg-[#C9A84C]"></div>
          <div class="h-px w-10 bg-[#C9A84C]"></div>
        </div>
        <h2
          class="font-serif font-medium text-[#820057] text-[2.8rem] leading-[1.1] tracking-tight mb-0"
        >
          El arte en cada bocado
        </h2>
      </div>

      <!-- Imágenes apiladas con offset alterno -->
      <div class="stitch-collage w-full flex flex-col gap-4 flex-1">
        <div
          class="self-end w-[72%] aspect-[4/3] bg-white stitch-img-card"
          style="box-shadow: 0 4px 16px rgba(30,27,24,0.08);"
        >
          <img
            src="https://images.unsplash.com/photo-1569864358642-9d1684040f43?q=80&w=800&auto=format&fit=crop"
            alt="Macarons artesanales en tonos pastel"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
        <div
          class="self-start w-[60%] aspect-[4/3] bg-white stitch-img-card"
          style="box-shadow: 0 4px 16px rgba(30,27,24,0.08);"
        >
          <img
            src="https://images.unsplash.com/photo-1551024506-0bccd828d307?q=80&w=600&auto=format&fit=crop"
            alt="Petit four de chocolate"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div
          class="self-end w-[72%] aspect-[4/3]"
          style="background: #1e1b18; box-shadow: 0 4px 16px rgba(30,27,24,0.14);"
        >
          <img
            src="https://images.unsplash.com/photo-1565958011703-44f9829ba187?q=80&w=800&auto=format&fit=crop"
            alt="Tarta artesanal con frutos rojos"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- CTA -->
      <div class="stitch-text mt-10 mb-4 w-full flex justify-center">
        <a
          href="/menu"
          class="stitch-cta inline-flex items-center gap-3 bg-[#820057] text-white px-10 py-4 text-base font-medium tracking-[0.08em] rounded"
        >
          Descubrir Colección
          <i class="fa-solid fa-arrow-right text-sm"></i>
        </a>
      </div>
    </div>

    <!-- ── DESKTOP: layout asimétrico 12 columnas (original) ── -->
    <div class="hidden lg:block max-w-7xl mx-auto w-full px-20 py-0">
      <div class="grid lg:grid-cols-12 gap-6 items-center">
        <!-- Texto: 4 columnas -->
        <div class="lg:col-span-4 lg:col-start-1 stitch-text">
          <h2
            class="font-serif font-medium text-[#820057] text-6xl xl:text-7xl leading-[1.1] tracking-tight mb-10"
          >
            El arte en<br />cada bocado
          </h2>
          <a
            href="/menu"
            class="stitch-cta inline-flex items-center gap-3 bg-[#820057] text-white px-8 py-3.5 text-sm font-medium tracking-[0.08em] rounded"
          >
            Descubrir Colección
            <i class="fa-solid fa-arrow-right text-xs"></i>
          </a>
        </div>

        <!-- Collage: 7 columnas -->
        <div class="lg:col-span-7 lg:col-start-6 relative stitch-collage">
          <div
            class="relative lg:mr-0 aspect-[5/5.5]"
            style="background: #f5ece7;"
          >
            <div
              class="stitch-card-1 absolute top-[8%] right-[8%] w-[52%] aspect-square bg-white p-3"
              style="box-shadow: 0 1px 2px rgba(30,27,24,0.05);"
            >
              <img
                src="https://images.unsplash.com/photo-1569864358642-9d1684040f43?q=80&w=800&auto=format&fit=crop"
                alt="Macarons artesanales en tonos pastel"
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
            <div
              class="stitch-card-2 absolute top-[38%] left-[6%] w-[38%] aspect-square bg-white p-3"
              style="box-shadow: 0 1px 2px rgba(30,27,24,0.05);"
            >
              <img
                src="https://images.unsplash.com/photo-1551024506-0bccd828d307?q=80&w=600&auto=format&fit=crop"
                alt="Petit four de chocolate con detalle dorado"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div
              class="stitch-card-3 absolute bottom-[-6%] right-[-5%] w-[58%] aspect-[1/1]"
              style="background: #1e1b18; box-shadow: 0 2px 8px rgba(30,27,24,0.12);"
            >
              <img
                src="https://images.unsplash.com/photo-1565958011703-44f9829ba187?q=80&w=800&auto=format&fit=crop"
                alt="Tarta artesanal con frutos rojos sobre fondo oscuro"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ── Hero Stitch: entrance ── */
    #hero-stitch.hero-active {
      display: flex;
    }

    .stitch-text,
    .stitch-collage {
      opacity: 0;
      transform: translateY(24px);
    }
    #hero-stitch.hero-active .stitch-text {
      animation: stitchUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.15s both;
    }
    #hero-stitch.hero-active .stitch-collage {
      animation: stitchUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.3s both;
    }
    @keyframes stitchUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Soft inner glow on plum CTA (DESIGN.md §Elevation) */
    .stitch-cta {
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
      transition: background 0.3s ease;
    }
    .stitch-cta:hover {
      background: #5a003b;
    }

    @media (prefers-reduced-motion: reduce) {
      .stitch-text,
      .stitch-collage {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
    }
  </style>

  <!-- HERO SECTION — VARIANTE 3D (texto centrado) -->
  <section
    id="hero-3d"
    class="relative min-h-[100dvh] hidden flex-col items-center justify-center overflow-hidden pt-16 lg:pt-20"
    style="background: #fdf3ee;"
  >
    <div class="relative z-10 text-center px-6 p3d-content">
      <div class="flex items-center justify-center gap-3 mb-8">
        <div class="h-px w-10 bg-[#C9A84C]"></div>
        <div class="w-1.5 h-1.5 rotate-45 bg-[#C9A84C]"></div>
        <div class="h-px w-10 bg-[#C9A84C]"></div>
      </div>

      <h2
        class="font-serif font-medium text-[#820057] leading-[1.05] tracking-tight mb-8"
        style="font-size: clamp(3rem, 8vw, 7rem)"
      >
        El arte en<br /><em class="italic text-gold font-light">cada bocado</em>
      </h2>

      <p
        class="text-[#55414a]/70 font-light text-lg lg:text-xl max-w-md mx-auto mb-10 leading-relaxed"
      >
        Pastelería fina artesanal en Valladolid
      </p>

      <a
        href="/menu"
        class="stitch-cta inline-flex items-center gap-3 bg-[#820057] text-white px-9 py-4 text-base font-medium tracking-[0.08em] rounded"
      >
        Descubrir Colección
        <i class="fa-solid fa-arrow-right text-xs"></i>
      </a>
    </div>
  </section>

  <style>
    #hero-3d.hero-active {
      display: flex;
    }

    /* ── Texto: entrada ── */
    .p3d-content {
      opacity: 0;
      transform: translateY(24px);
    }
    #hero-3d.hero-active .p3d-content {
      animation: stitchUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.15s both;
    }

    @media (prefers-reduced-motion: reduce) {
      .p3d-content {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
    }
  </style>

  <script is:inline>
    /* ---- Hero variant switcher ---- */
    (function () {
      var heroes = {
        classic: document.getElementById("hero"),
        stitch: document.getElementById("hero-stitch"),
        "3d": document.getElementById("hero-3d"),
      };
      if (!heroes.classic || !heroes.stitch || !heroes["3d"]) return;

      function apply(variant) {
        if (!heroes[variant]) variant = "classic";
        heroes.classic.style.display = variant === "classic" ? "" : "none";
        ["stitch", "3d"].forEach(function (key) {
          var active = variant === key;
          heroes[key].classList.toggle("hidden", !active);
          heroes[key].classList.toggle("hero-active", active);
        });
      }

      var saved = "classic";
      try {
        saved = localStorage.getItem("matizes_hero_variant") || "classic";
      } catch (e) {}
      apply(saved);

      document.addEventListener("hero:variant", function (e) {
        apply(e.detail);
      });
    })();
  </script>

  <!-- BRAND STATEMENT -->
  <section id="brand-statement" class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal-left">
          <p class="section-tag mb-5">Nuestra Filosofía</p>
          <h2
            class="font-serif text-4xl lg:text-5xl xl:text-6xl font-light text-purple leading-snug mb-6"
          >
            Donde la técnica<br />
            encuentra el <em class="italic text-gold">alma</em>
          </h2>
          <div class="gold-line h-px w-16 mb-6"></div>
          <p
            class="text-gray-600 font-light leading-relaxed mb-5 text-base lg:text-lg"
          >
            En <MatizesWordmark
              class="inline-block h-[0.78em] w-auto align-[-0.04em] text-purple"
            /> creemos que la pastelería fina es una forma de arte. Cada creación
            nace de la precisión técnica y la pasión por los sabores auténticos.
          </p>
          <p
            class="text-gray-600 font-light leading-relaxed mb-8 text-base lg:text-lg"
          >
            Trabajamos con ingredientes de primera calidad, técnicas clásicas y
            una visión contemporánea para ofrecerte experiencias únicas en cada
            pieza.
          </p>

          <a
            href="#featured-products"
            class="btn-purple inline-flex items-center gap-3 px-8 py-3.5 font-medium text-sm tracking-widest uppercase"
          >
            Conocer Más <i class="fa-solid fa-arrow-right text-xs"></i>
          </a>
        </div>
        <div class="relative reveal-right">
          <div
            class="absolute -top-4 -left-4 w-full h-full border border-gold/30 z-0"
          >
          </div>
          <div
            class="relative z-10 h-[420px] lg:h-[520px] overflow-hidden img-hover-wrap"
          >
            <img
              class="w-full h-full object-cover"
              src="https://storage.googleapis.com/uxpilot-auth.appspot.com/1c4c05253a-2bef564969f2e25e9664.png"
              alt="pastry chef hands carefully decorating an elegant cake, fine patisserie, artisanal detail, editorial food photography"
            />
          </div>
          <div class="absolute -bottom-6 -right-6 bg-purple p-6 z-20">
            <p class="font-serif text-xl text-gold italic">
              "Tira y vete Cacahuete"
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section id="featured-products" class="py-20 lg:py-28 bg-cream-dark">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div
        class="reveal flex flex-col md:flex-row md:items-end justify-between mb-12 lg:mb-16 gap-6"
      >
        <div>
          <h2 class="font-serif text-4xl lg:text-5xl font-light text-purple">
            Nuestras <em class="italic text-gold">Estrellas</em>
          </h2>
        </div>
        <a
          href="/menu"
          class="inline-flex items-center gap-2 text-purple font-medium text-sm tracking-widest uppercase border-b border-purple pb-1 hover:text-gold hover:border-gold transition-colors self-start md:self-auto"
        >
          Ver todo el menú <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>

      <div
        class="stagger-grid grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8"
      >
        {
          [
            "cheesecake-roll",
            "calendario-azteca",
            "brownie",
            "tarta-queso-cabra",
            "flor-de-la-pasion",
            "cubisant",
          ]
            .map((id) => products.find((p) => p.id === id))
            .filter(Boolean)
            .map((product) => <ProductCard product={product!} />)
        }
      </div>
    </div>
  </section>

  <!-- CATEGORIES BAND -->
  <section id="categories" class="py-20 lg:py-28 bg-purple">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="reveal text-center mb-12 lg:mb-16">
        <h2 class="font-serif text-4xl lg:text-5xl font-light text-white">
          Categorías del <em class="italic text-gold">Menú</em>
        </h2>
      </div>
      <div class="stagger-grid grid grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-7">
        <a
          href="/menu#viennoiserie"
          id="cat-1"
          class="cat-card group relative cursor-pointer overflow-hidden h-52 lg:h-64 block"
        >
          <img
            class="cat-card-img w-full h-full object-cover"
            src="https://storage.googleapis.com/uxpilot-auth.appspot.com/be0ca15106-b7cbc54a3b2af8cf47a6.png"
            alt="artisan croissants and rolls, fine bakery"
          />
          <div
            class="cat-card-overlay absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 right-0 p-5 transition-transform duration-500 group-hover:-translate-y-1"
          >
            <h3 class="font-serif text-xl text-white font-light">
              Viennoiserie
            </h3>
            <div
              class="h-px bg-gold mt-2 w-0 group-hover:w-12 transition-all duration-500"
            >
            </div>
          </div>
          <div
            class="absolute top-4 right-4 flex items-center gap-2 text-gold opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          >
            <span class="text-xs tracking-widest uppercase">Ver</span>
            <i class="fa-solid fa-arrow-up-right-from-square text-sm"></i>
          </div>
        </a>
        <a
          href="/menu#cakes-autor"
          id="cat-2"
          class="cat-card group relative cursor-pointer overflow-hidden h-52 lg:h-64 block"
        >
          <img
            class="cat-card-img w-full h-full object-cover"
            src="https://storage.googleapis.com/uxpilot-auth.appspot.com/96fb75ed41-f75b3674eca840ad9ed0.png"
            alt="artisan cakes and brownies, fine patisserie"
          />
          <div
            class="cat-card-overlay absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 right-0 p-5 transition-transform duration-500 group-hover:-translate-y-1"
          >
            <h3 class="font-serif text-xl text-white font-light">
              Cakes de Autor
            </h3>
            <div
              class="h-px bg-gold mt-2 w-0 group-hover:w-12 transition-all duration-500"
            >
            </div>
          </div>
          <div
            class="absolute top-4 right-4 flex items-center gap-2 text-gold opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          >
            <span class="text-xs tracking-widest uppercase">Ver</span>
            <i class="fa-solid fa-arrow-up-right-from-square text-sm"></i>
          </div>
        </a>
        <a
          href="/menu#cookies"
          id="cat-3"
          class="cat-card group relative cursor-pointer overflow-hidden h-52 lg:h-64 block"
        >
          <img
            class="cat-card-img w-full h-full object-cover"
            src="https://storage.googleapis.com/uxpilot-auth.appspot.com/52dc8885f9-7b96135997d58656e6a1.png"
            alt="gourmet cookies assortment, fine bakery"
          />
          <div
            class="cat-card-overlay absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 right-0 p-5 transition-transform duration-500 group-hover:-translate-y-1"
          >
            <h3 class="font-serif text-xl text-white font-light">
              Cookies Gourmet
            </h3>
            <div
              class="h-px bg-gold mt-2 w-0 group-hover:w-12 transition-all duration-500"
            >
            </div>
