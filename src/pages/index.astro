  <script is:inline>
    (function () {
      function initials(name) {
        return name
          .split(" ")
          .map(function (w) {
            return w[0];
          })
          .join("")
          .slice(0, 2)
          .toUpperCase();
      }
      function stars(rating) {
        var html = "";
        for (var i = 1; i <= 5; i++) {
          html +=
            '<i class="fa-solid fa-star text-sm ' +
            (i <= rating ? "text-gold" : "text-gray-200") +
            '"></i>';
        }
        return html;
      }
      function renderCard(r) {
        var avatar = r.profilePhoto
          ? '<img src="' +
            r.profilePhoto +
            '" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="' +
            r.author +
            '" />'
          : '<div class="w-10 h-10 rounded-full bg-purple flex items-center justify-center flex-shrink-0"><span class="text-gold text-xs font-bold tracking-wide">' +
            initials(r.author) +
            "</span></div>";
        return (
          '<div class="testimonial-card bg-cream p-8 flex flex-col">' +
          '<div class="flex gap-1 mb-5">' +
          stars(r.rating) +
          "</div>" +
          '<p class="font-serif text-lg text-gray-700 italic font-light leading-relaxed mb-6 flex-grow">"' +
          r.text +
          '"</p>' +
          '<div class="flex items-center gap-3 pt-4 border-t border-gold/15">' +
          avatar +
          '<div><p class="text-purple font-medium text-sm">' +
          r.author +
          "</p>" +
          '<p class="text-gray-400 text-xs tracking-wide">' +
          r.relativeTime +
          "</p></div>" +
          '<i class="fa-brands fa-google text-gray-300 ml-auto text-lg"></i>' +
          "</div></div>"
        );
      }

      fetch("https://matizes-google-reviews.tusubdominio.workers.dev")
        .then(function (res) {
          return res.ok ? res.json() : null;
        })
        .then(function (data) {
          if (!data || !data.reviews || data.reviews.length === 0) return;
          /* Update rating bar */
          if (data.rating) {
            document.getElementById("reviews-rating").textContent = data.rating
              .toFixed(1)
              .replace(".", ",");
          }
          if (data.totalReviews) {
            document.getElementById("reviews-count").textContent =
              "Basado en " + data.totalReviews + " reseñas";
          }
          /* Replace grid with real reviews (max 5) */
          var grid = document.getElementById("reviews-grid");
          var top = data.reviews
            .filter(function (r) {
              return r.text && r.text.length > 40;
            })
            .slice(0, 5);
          if (top.length >= 3) {
            grid.innerHTML = top.map(renderCard).join("");
          }
        })
        .catch(function () {
          /* silently keep fallback */
        });
    })();
  </script>

