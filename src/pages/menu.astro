---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import { tartasMenu, getProductsByCategory } from '../data/products';

const viennoiserie = getProductsByCategory('Viennoiserie');
const cakesAutor = getProductsByCategory('Cakes de Autor');
const cheesecakes = getProductsByCategory('Cheesecakes');
const cookiesGourmet = getProductsByCategory('Cookies Gourmet');
const creaciones = getProductsByCategory('Creaciones Individuales');

const formatPrice = (n: number) => n.toFixed(2).replace('.', ',');
---

<Layout title="Menú — Viennoiserie, Cakes, Creaciones y Tartas | Mat!zes" description="Descubre el menú de Mat!zes: viennoiserie, cakes de autor, cheesecakes, cookies gourmet, creaciones individuales y tartas artesanales en Valladolid." ogUrl="https://matizes.es/menu">
  <Header />

  <!-- Spacer for fixed header -->
  <div class="h-16 lg:h-20"></div>

  <!-- HERO -->
  <section class="py-16 lg:py-24 bg-purple relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 rounded-full border border-gold" style="transform: translate(30%, -30%)"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full border border-gold" style="transform: translate(-30%, 30%)"></div>
    </div>
    <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 text-center">
      <div class="reveal">
        <p class="section-tag mb-4 text-gold/70">Explora nuestra oferta</p>
        <h1 class="font-serif text-4xl lg:text-6xl font-light text-white">Carta de <em class="italic text-gold">Creaciones</em></h1>
        <div class="gold-line h-px w-24 mx-auto mt-6"></div>
        <p class="text-white/70 font-light max-w-xl mx-auto mt-6">Descubre nuestra selección completa de viennoiserie, cakes de autor, cheesecakes, cookies gourmet, creaciones individuales y tartas artesanales.</p>
      </div>
    </div>
  </section>

  <!-- Quick nav -->
  <section class="bg-cream-dark border-b border-gold/15 sticky top-16 lg:top-20 z-30">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="flex flex-wrap items-center justify-center gap-4 lg:gap-8 py-4">
        <a href="#viennoiserie" class="text-xs tracking-widest uppercase text-purple hover:text-gold transition-colors">Viennoiserie</a>
        <a href="#cakes-autor" class="text-xs tracking-widest uppercase text-purple hover:text-gold transition-colors">Cakes de Autor</a>
        <a href="#cheesecakes" class="text-xs tracking-widest uppercase text-purple hover:text-gold transition-colors">Cheesecakes</a>
        <a href="#cookies" class="text-xs tracking-widest uppercase text-purple hover:text-gold transition-colors">Cookies</a>
        <a href="#creaciones" class="text-xs tracking-widest uppercase text-purple hover:text-gold transition-colors">Creaciones</a>
        <a href="#tartas" class="text-xs tracking-widest uppercase text-purple hover:text-gold transition-colors">Tartas</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       VIENNOISERIE
       ═══════════════════════════════════════════════ -->
  <section id="viennoiserie" class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="reveal flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
        <div>
          <h2 class="font-serif text-4xl lg:text-5xl font-light text-purple">Viennoiser<em class="italic text-gold">ie</em></h2>
          <div class="gold-line h-px w-16 mt-4"></div>
        </div>
        <p class="text-xs text-gray-500 tracking-widest uppercase">{viennoiserie.length} creaciones</p>
      </div>
      <div class="stagger-grid grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {viennoiserie.map((product) => (<ProductCard product={product} />))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CAKES DE AUTOR
       ═══════════════════════════════════════════════ -->
  <section id="cakes-autor" class="py-16 lg:py-24 bg-cream-dark">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="reveal flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
        <div>
          <h2 class="font-serif text-4xl lg:text-5xl font-light text-purple">Cakes de <em class="italic text-gold">Autor</em></h2>
          <div class="gold-line h-px w-16 mt-4"></div>
        </div>
        <p class="text-xs text-gray-500 tracking-widest uppercase">{cakesAutor.length} creaciones</p>
      </div>
      <div class="stagger-grid grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {cakesAutor.map((product) => (<ProductCard product={product} />))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CHEESECAKES
       ═══════════════════════════════════════════════ -->
  <section id="cheesecakes" class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="reveal flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
        <div>
          <h2 class="font-serif text-4xl lg:text-5xl font-light text-purple">Cheese<em class="italic text-gold">cakes</em></h2>
          <div class="gold-line h-px w-16 mt-4"></div>
        </div>
        <p class="text-xs text-gray-500 tracking-widest uppercase">{cheesecakes.length} creaciones</p>
      </div>
      <div class="stagger-grid grid sm:grid-cols-2 lg:grid-cols-2 gap-6 lg:gap-8 max-w-3xl">
        {cheesecakes.map((product) => (<ProductCard product={product} />))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       COOKIES GOURMET
       ═══════════════════════════════════════════════ -->
  <section id="cookies" class="py-16 lg:py-24 bg-cream-dark">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="reveal flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
        <div>
          <h2 class="font-serif text-4xl lg:text-5xl font-light text-purple">Cookies <em class="italic text-gold">Gourmet</em></h2>
          <div class="gold-line h-px w-16 mt-4"></div>
        </div>
        <p class="text-xs text-gray-500 tracking-widest uppercase">{cookiesGourmet.length} creaciones</p>
      </div>
      <div class="stagger-grid grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {cookiesGourmet.map((product) => (<ProductCard product={product} />))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CREACIONES INDIVIDUALES
       ═══════════════════════════════════════════════ -->
  <section id="creaciones" class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="reveal flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
        <div>
          <h2 class="font-serif text-4xl lg:text-5xl font-light text-purple">Creaciones <em class="italic text-gold">Individuales</em></h2>
          <div class="gold-line h-px w-16 mt-4"></div>
        </div>
        <p class="text-xs text-gray-500 tracking-widest uppercase">{creaciones.length} creaciones</p>
      </div>
      <div class="stagger-grid grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {creaciones.map((product) => (<ProductCard product={product} />))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TARTAS — Tabla de tamaños y precios
       ═══════════════════════════════════════════════ -->
  <section id="tartas" class="py-16 lg:py-24 bg-purple relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-80 h-80 rounded-full border border-gold" style="transform: translate(-25%, -25%)"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 rounded-full border border-gold" style="transform: translate(25%, 25%)"></div>
    </div>
    <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
      <div class="reveal text-center mb-12 lg:mb-16">
        <h2 class="font-serif text-4xl lg:text-5xl font-light text-white">Nuestras <em class="italic text-gold">Tartas</em></h2>
        <div class="gold-line h-px w-24 mx-auto mt-6"></div>
        <p class="text-white/60 font-light max-w-lg mx-auto mt-6">Elaboradas por encargo. Todos los sabores disponibles en varios tamaños.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {tartasMenu.map((cat) => (
          <div class="bg-white/5 border border-white/10 p-6 lg:p-8 backdrop-blur-sm">
            <h3 class="font-serif text-2xl text-gold font-light mb-2">{cat.title}</h3>
            {cat.subtitle && <p class="text-white/50 text-sm font-light mb-4">{cat.subtitle}</p>}
            <div class="gold-line h-px w-12 mb-6"></div>

            {cat.items.map((item) => (
              <div>
                {item.description && <p class="text-white/60 text-sm font-light mb-4">{item.description}</p>}
                <div class="space-y-3">
                  {item.sizes.map((size) => (
                    <div class="flex items-center justify-between py-2 border-b border-white/10 last:border-0">
                      <div>
                        <span class="text-white font-light">{size.name}</span>
                        <span class="text-white/40 text-sm ml-2">{size.servings}</span>
                      </div>
                      <span class="font-serif text-xl text-gold">{formatPrice(size.price)} €</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TARTAS BBC POR ENCARGO — Sección existente
       ═══════════════════════════════════════════════ -->
  <section class="py-16 lg:py-24 bg-cream relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <!-- Texto -->
        <div class="order-2 lg:order-1 reveal-left">
          <h2 class="font-serif text-4xl lg:text-5xl font-light text-purple leading-snug mb-6">
            ¿Buscas algo<br/>
            <em class="italic text-gold">especial?</em>
          </h2>
          <div class="gold-line h-px w-16 mb-6"></div>
          <p class="text-gray-600 font-light leading-relaxed mb-8 max-w-md">
            Diseñamos creaciones personalizadas para bodas, eventos y celebraciones únicas. Cuéntanos tu visión y la convertiremos en una obra de sabor.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contacto" class="btn-gold inline-flex items-center justify-center gap-3 px-8 py-3.5 font-medium text-sm tracking-widest uppercase">
              <i class="fa-regular fa-envelope text-xs"></i> Solicitar Pedido
            </a>
            <a href="https://wa.me/34612345678" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-3 px-8 py-3.5 border border-purple/40 text-purple font-medium text-sm tracking-widest uppercase hover:border-gold hover:text-gold transition-colors">
              <i class="fa-brands fa-whatsapp text-sm"></i> WhatsApp
            </a>
          </div>
        </div>

        <!-- Mosaico de imágenes -->
        <div class="order-1 lg:order-2 stagger-grid grid grid-cols-2 gap-4">
          <div class="h-44 lg:h-52 overflow-hidden">
            <img class="w-full h-full object-cover" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/d5c590a30e-598ca973c003b8932b79.png" alt="pastel de boda de dos pisos con flores rosas" />
          </div>
          <div class="h-44 lg:h-52 overflow-hidden">
            <img class="w-full h-full object-cover" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/1c4c05253a-2bef564969f2e25e9664.png" alt="pastelero decorando un pastel artesanal" />
          </div>
          <div class="h-44 lg:h-52 overflow-hidden">
            <img class="w-full h-full object-cover" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/7438793c2a-f6fd1c1966279610809f.png" alt="pastel personalizado con detalles dorados" />
          </div>
          <div class="h-44 lg:h-52 overflow-hidden">
            <img class="w-full h-full object-cover" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/52dc8885f9-7b96135997d58656e6a1.png" alt="bombones y chocolates artesanales" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
