# Google Places API — solo se usa en el Cloudflare Worker, NO en el frontend
# La key NUNCA va aquí en producción. Se añade con:
#   cd cloudflare-worker
#   wrangler secret put GOOGLE_PLACES_API_KEY
#
# Pasos para activar:
# 1. https://console.cloud.google.com → Nuevo proyecto
# 2. APIs → Places API (New) → Habilitar
# 3. Credenciales → Crear clave de API
GOOGLE_PLACES_API_KEY=TU_API_KEY_AQUI

# Place ID ya conocido — está hardcodeado en cloudflare-worker/google-reviews.js
# Matizes Pastelería, C. Colón 6, Valladolid
# GOOGLE_PLACE_ID=ChIJV3xQEB4TRw0RIU86WohTnT4
